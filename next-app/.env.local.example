# Supabase — copie este arquivo para .env.local e preencha
# Encontre em: supabase.com → seu projeto → Settings → API

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anônima (segura para o browser — RLS garante o isolamento)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave de serviço — NUNCA coloque com prefixo NEXT_PUBLIC_
# Usada apenas em Server Actions e API Routes
SUPABASE_SERVICE_ROLE_KEY=eyJ...
